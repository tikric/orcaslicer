{
  "name": "@lovable.dev/vite-plugin-dev-server-bridge",
  "version": "1.1.2",
  "description": "Vite plugin exposing a loopback-only control-plane endpoint that broadcasts dev-server lifecycle events over the HMR WebSocket",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "files": [
    "dist"
  ],
  "keywords": [
    "vite",
    "plugin",
    "hmr",
    "lovable"
  ],
  "license": "MIT",
  "peerDependencies": {
    "vite": ">=5.0.0 <9.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/node": "22.13.13",
    "rimraf": "^5.0.0",
    "tsdown": "^0.22.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "directories": {
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lovablelabs/lovable.git",
    "directory": "npm-packages/vite-plugin-dev-server-bridge"
  },
  "scripts": {
    "build": "tsdown",
    "check:package": "tmp=$(mktemp -d) && pnpm pack --out \"$tmp/pkg.tgz\" && tar -xzf \"$tmp/pkg.tgz\" -C \"$tmp\" && publint \"$tmp/package\" --strict && attw \"$tmp/pkg.tgz\"",
    "typecheck": "tsgo --noEmit",
    "dev": "tsdown --watch",
    "test": "vitest",
    "clean": "rimraf dist"
  }
}